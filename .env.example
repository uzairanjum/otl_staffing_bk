# Database Configuration
# Local MongoDB with no auth: mongodb://localhost:27017/otl_staffing
# Docker Compose (run seed on host; match MONGO_APP_USER / MONGO_APP_PASSWORD in docker-compose and mongo-init):
#   mongodb://otl_user:otl_password@localhost:27017/otl_staffing?authSource=otl_staffing
# Production with Atlas: mongodb+srv://username:password@cluster.mongodb.net/otl_staffing
MONGODB_URI=mongodb://localhost:27017/otl_staffing

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_key_here_change_in_production
JWT_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d

# Cloudinary Configuration (Image Upload)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Firebase Configuration (Push Notifications)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# SMTP Configuration (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Papertrail Configuration (Logging)
PAPERTRAIL_HOST=logs1.papertrailapp.com
PAPERTRAIL_PORT=12345

# Frontend URL
FRONTEND_URL=http://localhost:3001

# Optional: Filter cache TTL in milliseconds
FILTER_CACHE_TTL_MS=60000
